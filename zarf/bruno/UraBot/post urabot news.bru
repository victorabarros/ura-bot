meta {
  name: post urabot news
  type: http
  seq: 3
}

post {
  url: {{urabotBaseUrl}}/urabot/news
  body: json
  auth: apikey
}

headers {
  authorization: {{UrabotXToken}}
}

auth:apikey {
  key: authorization
  value: McChickenPromo
  placement: header
}

body:json {
  {
    "generateImage": true
  }
}
