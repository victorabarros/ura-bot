{
  "name": "ura-bot",
  "version": "2.0.0",
  "description": "A bot that posts uranium market stock quotes and news to X and Nostr.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "http-status": "^1.7.4",
    "moment-timezone": "^0.5.46",
    "replicate": "^1.0.1",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.9",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=20"
  }
}
